# .env.example
# Upbit 하이브리드 터틀 자동매매 — 환경변수 설정 템플릿
#
# 사용 방법:
#   이 파일을 복사해서 ".env" 라는 이름으로 저장한 뒤,
#   각 항목의 값을 실제 값으로 채운다.
#   .env 파일은 절대 git 에 올리지 않는다.

# ─────────────────────────────────────
# Upbit API 설정
# ─────────────────────────────────────

# Upbit Access Key (개발자 센터에서 발급, https://upbit.com/service_center/open_api_guide)
UPBIT_ACCESS_KEY=fPJvitdPs4vlPxxEILlLmLdDr8wwhEZrwHiTfF6Q

# Upbit Secret Key
UPBIT_SECRET_KEY=rlx8Hl4xKBuIswbTFxN4I2gr8oKyTNNw1jl1pBKd

# 계좌 별칭 (로그·Google Sheet 기록용)
UPBIT_ACCOUNT_LABEL=hybrid_turtle

# ─────────────────────────────────────
# 텔레그램 알림 설정
# ─────────────────────────────────────

# 텔레그램 봇 토큰 (BotFather 에서 발급)
TELEGRAM_BOT_TOKEN=7566573450:AAGc1ZV-nfOSeMRldOh7iM34xBoxDj8DBDE

# 텔레그램 채팅 ID (본인 채팅방 또는 그룹 ID)
TELEGRAM_CHAT_ID=6847524018

# ─────────────────────────────────────
# Google Sheets 연동 설정 (체결 원장 저장)
# ─────────────────────────────────────

# Google 서비스 계정 JSON 파일 경로 (없으면 Sheets 저장 비활성, 로컬 JSON 만 저장)
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Google Sheets 스프레드시트 제목
GOOGLE_SPREADSHEET_TITLE=hybrid_turtle_trade_history

# (선택) 스프레드시트를 저장할 Google Drive 폴더 ID (비우면 내 드라이브 루트)
GOOGLE_DRIVE_FOLDER_ID=1ZCu9nCufwS2F-TJojY3Z0h915qHrHRNQ

# ─────────────────────────────────────
# 포트폴리오 추이·누적수익률 계산용 초기자본
# ─────────────────────────────────────

# 운용 시작 시점의 초기 자본 (원)
# 비워두면 '포트폴리오 추이' 시트의 누적수익률(%)은 기록하지 않는다.
UPBIT_INITIAL_CAPITAL=10000000
